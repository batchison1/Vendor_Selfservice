# Auth seam: "dev" = local fake user (no Entra); "entra" = real MSAL sign-in.
REACT_APP_AUTH_MODE=dev

# VSS backend (BFF) base URL.
REACT_APP_VSS_API_DOMAIN=http://localhost:5047

# Unity/UDP runtime config (used by ConfigService). Fill real values on the network.
REACT_APP_UNITY_API_DOMAIN=https://gateway.unitydev.ca
REACT_APP_UNITY_URL=https://unitydev.ca
REACT_APP_UNITY_TENANT_ID=
REACT_APP_UNITY_PRODUCT_ID=vss
REACT_APP_UNITY_VERTICAL_ID=

# MSAL (only needed when REACT_APP_AUTH_MODE=entra)
REACT_APP_ENTRA_CLIENT_ID=
REACT_APP_ENTRA_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
REACT_APP_VSS_API_SCOPE=api://<vss-api-client-id>/access_as_user
